# Nebula CRM - Environment Template
# Copy to .env and fill with real values. Do NOT commit secrets.

# Runtime
APP_ENVIRONMENT=development
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# Server
PORT=8080
API_BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nebula

# Auth (authentik) — see docker/authentik/blueprints/nebula-dev.yaml
# Generate AUTHENTIK_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
AUTHENTIK_SECRET_KEY=replace_me
AUTHENTIK_BOOTSTRAP_PASSWORD=replace_me
AUTHENTIK_DEV_USER_PASSWORD=replace_me

# AI / LLM
ANTHROPIC_API_KEY=replace_me

# Observability
LOG_LEVEL=info
