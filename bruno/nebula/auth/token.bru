meta {
  name: Get Access Token
  type: http
  seq: 1
}

post {
  url: {{tokenUrl}}
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  grant_type: password
  client_id: {{clientId}}
  username: {{username}}
  password: {{password}}
  scope: openid profile email nebula_roles
}

assert {
  res.status: eq 200
  res.body.access_token: isDefined
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("accessToken", res.body.access_token);
  }
}
