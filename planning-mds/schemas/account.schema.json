{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/account.schema.json",
  "title": "Account",
  "description": "Insured account aggregate for F0016. Tombstone-aware: Merged accounts include survivorAccountId; Deleted accounts return 410 Gone from GET and are not represented by this schema. See ADR-017.",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "stableDisplayName",
    "status",
    "rowVersion",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "displayName": { "type": "string", "maxLength": 200 },
    "stableDisplayName": { "type": "string", "maxLength": 200, "description": "Snapshot used by dependent-view fallback contract. Frozen at Merged or Deleted." },
    "legalName": { "type": ["string", "null"], "maxLength": 200 },
    "taxId": { "type": ["string", "null"], "maxLength": 50 },
    "industry": { "type": ["string", "null"], "maxLength": 100 },
    "primaryLineOfBusiness": { "type": ["string", "null"], "maxLength": 50 },
    "status": { "type": "string", "enum": ["Active", "Inactive", "Merged", "Deleted"] },
    "brokerOfRecordId": { "type": ["string", "null"], "format": "uuid" },
    "brokerOfRecordName": { "type": ["string", "null"] },
    "primaryProducerUserId": { "type": ["string", "null"], "format": "uuid" },
    "primaryProducerDisplayName": { "type": ["string", "null"] },
    "territoryCode": { "type": ["string", "null"], "maxLength": 50 },
    "region": { "type": ["string", "null"], "maxLength": 50 },
    "address1": { "type": ["string", "null"] },
    "address2": { "type": ["string", "null"] },
    "city": { "type": ["string", "null"] },
    "state": { "type": ["string", "null"] },
    "postalCode": { "type": ["string", "null"] },
    "country": { "type": ["string", "null"] },
    "mergedIntoAccountId": { "type": ["string", "null"], "format": "uuid" },
    "survivorAccountId": { "type": ["string", "null"], "format": "uuid" },
    "deleteReasonCode": { "type": ["string", "null"] },
    "deleteReasonDetail": { "type": ["string", "null"], "maxLength": 500 },
    "removedAt": { "type": ["string", "null"], "format": "date-time" },
    "rowVersion": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "createdByUserId": { "type": ["string", "null"], "format": "uuid" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "updatedByUserId": { "type": ["string", "null"], "format": "uuid" }
  },
  "additionalProperties": false
}
