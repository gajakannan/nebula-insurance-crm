{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/policy-reinstate-request.schema.json",
  "title": "PolicyReinstateRequest",
  "description": "Reinstate a Cancelled policy within the LOB-configured reinstatement window. Produces a new PolicyVersion (VersionReason=Reinstatement). See F0018-S0008.",
  "type": "object",
  "required": ["reinstatementReason"],
  "properties": {
    "reinstatementReason": {
      "type": "string",
      "enum": [
        "InsuredPaidOutstandingPremium",
        "CancellationInError",
        "AgreementReached",
        "Other"
      ]
    },
    "reinstatementDetail": {
      "type": ["string", "null"],
      "maxLength": 500,
      "description": "Required when reinstatementReason='Other'."
    }
  },
  "additionalProperties": false
}
