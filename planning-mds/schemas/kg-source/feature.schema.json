{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/kg-source/feature.schema.json",
  "title": "KG Source Feature Shard",
  "description": "A feature record under kg-source/features/**. Single home for the technical binding fields AND every fact the REGISTRY/ROADMAP tables project (F0006-S0004 §4). Conditional-required fields appear only when they apply.",
  "type": "object",
  "required": ["id", "name", "path", "status", "roadmap_section"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^feature:F[0-9]{4}$" },
    "name": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "in-progress", "planned", "planned-provisional", "superseded", "done", "archived-done", "retired"]
    },
    "phase": { "type": "string" },
    "roadmap_section": { "type": "string", "enum": ["Now", "Next", "Later", "Abandoned", "Completed"] },
    "rationale": { "type": "string" },
    "completion_state": { "type": "string" },
    "validation_gate": { "type": "string" },
    "affects": { "type": "array", "items": { "type": "string" } },
    "depends_on": { "type": "array", "items": { "type": "string" } },
    "governed_by": { "type": "array", "items": { "type": "string" } },
    "uses_api_contract": { "type": "array", "items": { "type": "string" } },
    "uses_schema": { "type": "array", "items": { "type": "string" } },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string", "pattern": "^feature:F[0-9]{4}$" },
    "retired_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "reason": { "type": "string" },
    "archived_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
  },
  "allOf": [
    {
      "if": { "properties": { "roadmap_section": { "enum": ["Now", "Next", "Later"] } }, "required": ["roadmap_section"] },
      "then": { "required": ["rationale"] }
    },
    {
      "if": { "properties": { "roadmap_section": { "const": "Completed" } }, "required": ["roadmap_section"] },
      "then": { "required": ["completion_state"] }
    },
    {
      "if": { "properties": { "roadmap_section": { "enum": ["Now", "Next", "Later", "Completed"] } }, "required": ["roadmap_section"] },
      "then": { "required": ["phase"] }
    },
    {
      "if": { "properties": { "status": { "enum": ["superseded", "retired"] } }, "required": ["status"] },
      "then": { "required": ["retired_date", "reason"] }
    },
    {
      "if": { "properties": { "status": { "const": "archived-done" } }, "required": ["status"] },
      "then": { "required": ["archived_date"] }
    }
  ]
}
