{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/producer-ownership-lookup-response.schema.json",
  "title": "ProducerOwnershipLookupResponse",
  "description": "Point-in-time producer ownership lookup result.",
  "type": "object",
  "required": ["scopeType", "scopeId", "asOf", "ownership"],
  "properties": {
    "scopeType": { "type": "string", "enum": ["Account", "BrokerRelationship"] },
    "scopeId": { "type": "string", "format": "uuid" },
    "asOf": { "type": "string", "format": "date" },
    "ownership": {
      "anyOf": [
        { "$ref": "https://nebula.local/schemas/producer-ownership.schema.json" },
        { "type": "null" }
      ]
    }
  },
  "additionalProperties": false
}
