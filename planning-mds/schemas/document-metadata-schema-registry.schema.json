{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/document-metadata-schema-registry.schema.json",
  "title": "DocumentMetadataSchemaRegistry",
  "description": "Lightweight registry stored under <docroot>/configuration/metadata-schemas/registry.yaml. It maps document type ids to versioned JSON Schema files.",
  "type": "object",
  "required": ["version", "schemas"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "currentVersion", "versions"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "currentVersion": {
            "type": "integer",
            "minimum": 1
          },
          "versions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["version", "file", "status"],
              "additionalProperties": false,
              "properties": {
                "version": {
                  "type": "integer",
                  "minimum": 1
                },
                "file": {
                  "type": "string",
                  "pattern": "^metadata-schemas/[A-Za-z0-9._-]+\\.schema\\.json$"
                },
                "status": {
                  "type": "string",
                  "enum": ["active", "deprecated"]
                }
              }
            }
          }
        }
      }
    }
  }
}
