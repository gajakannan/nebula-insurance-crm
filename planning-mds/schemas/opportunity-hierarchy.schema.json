{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/opportunity-hierarchy.schema.json",
  "title": "OpportunityHierarchy",
  "description": "Hierarchy tree response for opportunity composition views.",
  "type": "object",
  "required": [
    "periodDays",
    "root"
  ],
  "properties": {
    "periodDays": {
      "type": "integer",
      "minimum": 1,
      "maximum": 730
    },
    "root": {
      "$ref": "https://nebula.local/schemas/opportunity-hierarchy-node.schema.json"
    }
  },
  "additionalProperties": false
}
