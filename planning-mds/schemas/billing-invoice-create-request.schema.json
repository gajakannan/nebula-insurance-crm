{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/billing-invoice-create-request.schema.json",
  "title": "BillingInvoiceCreateRequest",
  "type": "object",
  "required": ["invoiceNumber", "policyId", "policyVersionId", "accountId", "currency", "originalAmount", "invoiceDate", "dueDate"],
  "properties": {
    "invoiceNumber": { "type": "string", "minLength": 1, "maxLength": 80 },
    "policyId": { "type": "string", "format": "uuid" },
    "policyVersionId": { "type": "string", "format": "uuid" },
    "accountId": { "type": "string", "format": "uuid" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "originalAmount": { "type": "number", "exclusiveMinimum": 0, "maximum": 9999999999999999.99, "multipleOf": 0.01 },
    "invoiceDate": { "type": "string", "format": "date" },
    "dueDate": { "type": "string", "format": "date" }
  },
  "additionalProperties": false
}
