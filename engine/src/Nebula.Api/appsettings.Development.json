{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=nebula;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Authority": "http://localhost:9000/application/o/nebula/",
    "Audience": "nebula"
  },
  "Documents": {
    "RootPath": "./data/documents",
    "MaxFileSizeBytes": 5242880,
    "MaxBatchSizeBytes": 52428800,
    "MaxBatchFiles": 25,
    "RetentionSweepIntervalMinutes": 60
  }
}
